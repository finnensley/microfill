{
  "name": "microfill",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "npx playwright test --config=playwright.config.ts",
    "test:e2e:prod": "PLAYWRIGHT_BASE_URL=https://microfill.vercel.app npx playwright test --config=playwright.config.ts",
    "test:routes": "vitest run tests/api/inventory-routes.test.ts tests/api/integrations-route.test.ts tests/api/webhooks-route.test.ts",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status",
    "supabase:env": "npx supabase status -o env",
    "supabase:reset": "npx supabase db reset",
    "supabase:types": "npx supabase gen types typescript --local --schema public > src/types/supabase.ts",
    "tunnel:shopify": "lt --port 3000",
    "webhook:replay:shopify": "node scripts/replay-shopify-order.mjs",
    "webhook:shopify:live:prepare": "node scripts/prepare-shopify-live-validation.mjs",
    "webhook:shopify:live:smoke": "node scripts/smoke-test-shopify-live-webhook.mjs",
    "webhook:shopify:live:verify": "node scripts/verify-shopify-live-validation.mjs",
    "webhook:replay:shiphero:po": "node scripts/replay-shiphero-webhook.mjs fixtures/shiphero/po-update.json",
    "webhook:replay:shiphero:shipment": "node scripts/replay-shiphero-webhook.mjs fixtures/shiphero/shipment-update.json",
    "webhook:shiphero:live:prepare": "node scripts/prepare-shiphero-live-validation.mjs",
    "webhook:shiphero:live:smoke": "node scripts/smoke-test-shiphero-live-webhook.mjs",
    "webhook:shiphero:live:verify": "node scripts/verify-shiphero-live-validation.mjs",
    "shiphero:simulate:scenarios": "node scripts/simulate-shiphero-scenarios.mjs",
    "shiphero:simulate:launch": "node scripts/simulate-shiphero-launch.mjs",
    "deploy:check": "node scripts/check-deploy-env.mjs",
    "supabase:link": "npx supabase link",
    "supabase:push": "SUPABASE_DB_PASSWORD=$SUPABASE_DB_PASSWORD npx supabase db push",
    "test:queue": "vitest run tests/api/webhook-queue.test.ts",
    "shopify:sync:verify": "node scripts/verify-shopify-outbound-sync.mjs",
    "shopify:sync:apply": "node scripts/verify-shopify-outbound-sync.mjs --apply",
    "shopify:sync:dry-run": "node scripts/verify-shopify-outbound-sync.mjs --dry-run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.98.0",
    "next": "^16.2.3",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "localtunnel": "^2.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
}
