NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54323
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DEFAULT_TENANT_ID=10000000-0000-0000-0000-000000000001
SHOPIFY_WEBHOOK_SECRET=replace-for-local-testing
SHIPHERO_WEBHOOK_SECRET=replace-for-local-testing

# Start the local stack first, then run `npm run supabase:env`
# and copy the printed values into .env.local.
# DEFAULT_TENANT_ID matches the seeded local inventory tenant.